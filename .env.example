# ==========================================
# Mira - Environment Variables Template
# ==========================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control!

# ===== Application =====
APP_ENV=development
DEBUG=true
BASE_URL=http://localhost:8000
LOG_LEVEL=INFO
SECRET_KEY=change-this-to-random-string-in-production

# ===== Telegram Bot =====
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_WEBHOOK_SECRET=random_secret_for_webhook_validation

# ===== LLM Providers =====
# Anthropic (Claude) - https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your_key_here

# OpenAI (for embeddings) - https://platform.openai.com
OPENAI_API_KEY=sk-your_key_here

# Optional: fallback providers
# GOOGLE_API_KEY=your_gemini_key
# GROQ_API_KEY=your_groq_key

# ===== Model Configuration =====
PRIMARY_MODEL=claude-opus-4-7
ROUTER_MODEL=claude-haiku-4-5
EMBEDDING_MODEL=text-embedding-3-small

# ===== Database =====
DATABASE_URL=postgresql+asyncpg://mira:mira_password@postgres:5432/mira_db
POSTGRES_USER=mira
POSTGRES_PASSWORD=mira_password
POSTGRES_DB=mira_db

# ===== Redis (Working Memory + Cache) =====
REDIS_URL=redis://redis:6379/0

# ===== Qdrant (Vector DB for Long-term Memory) =====
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=mira_memories

# ===== Langfuse (Observability) =====
# Get from https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=pk-lf-your_key
LANGFUSE_SECRET_KEY=sk-lf-your_key
LANGFUSE_HOST=https://cloud.langfuse.com

# ===== Optional: External APIs =====
# Tavily (for research agent)
# TAVILY_API_KEY=tvly-your_key

# ===== Rate Limiting =====
RATE_LIMIT_PER_MINUTE=30
RATE_LIMIT_PER_DAY=1000
